{
  "name": "my-electron-app",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "irving",
  "type": "commonjs",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm:electron-dev\"",
    "electron-dev": "cross-env NODE_ENV=development electron .",
    "electron-full": "concurrently \"npm run server\" \"npm run electron-dev\"",
    "build": "vite build",
    "start": "concurrently \"npm run server\" \"cross-env NODE_ENV=production electron .\"",
    "server": "node src/server/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "\\.agents"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleNameMapper": {
      "^@nodecfdi/(.*)$": "<rootDir>/tests/__mocks__/@nodecfdi.js"
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "eslint": "^10.4.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "wait-on": "^9.0.0"
  },
  "dependencies": {
    "@amcharts/amcharts5": "^5.16.1",
    "@amcharts/amcharts5-fonts": "^5.0.1",
    "@amcharts/amcharts5-geodata": "^5.1.5",
    "@e965/xlsx": "^0.20.3",
    "@marlon07021/facturama-nodejs-sdk": "^0.1.7",
    "@nodecfdi/cfdi-core": "^1.0.1",
    "@nodecfdi/cfdi-to-pdf": "^1.6.0",
    "@nodecfdi/credentials": "^2.0.3",
    "@prisma/client": "^7.8.0",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bootstrap-icons": "^1.13.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.5",
    "pdfkit": "^0.17.1",
    "pg": "^8.16.3",
    "prisma": "^7.8.0",
    "puppeteer": "^24.31.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "zklib-js-zkteko": "^1.3.4"
  }
}
