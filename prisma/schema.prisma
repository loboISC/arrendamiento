generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model accesorios {
  id_equipo             Int              @id(map: "equipos_pkey") @default(autoincrement())
  nombre                String           @db.VarChar(120)
  clave                 String           @unique(map: "idx_accesorios_clave_unique") @db.VarChar(40)
  peso                  Decimal?         @db.Decimal(8, 2)
  garantia              Decimal?         @db.Decimal(12, 2)
  descripcion           String?
  imagen                Bytes?
  venta                 Boolean?         @default(false)
  renta                 Boolean?         @default(false)
  estado                String?          @default("Disponible") @db.VarChar(30)
  ubicacion             String?          @db.VarChar(120)
  condicion             String?          @db.VarChar(30)
  tarifa_dia            Decimal?         @db.Decimal(10, 2)
  proximo_mantenimiento DateTime?        @db.Date
  categoria             String?          @db.VarChar(100)
  stock                 Int?             @default(1)
  precio_unitario       Decimal?         @db.Decimal(12, 2)
  tipo                  String?          @db.VarChar(10)
  tarifa                Decimal?         @default(0) @db.Decimal(14, 2)
  analisis              analisis[]
  componentes           componentes[]
  notificaciones        notificaciones[]
}

model almacenes {
  id_almacen     Int            @id @default(autoincrement())
  nombre_almacen String         @unique @db.VarChar(100)
  ubicacion      String?
  direccion      String?
  telefono       String?        @db.VarChar(20)
  cotizaciones   cotizaciones[]
  productos      productos[]
}

model analisis {
  id_analisis    Int         @id @default(autoincrement())
  tipo           String?     @db.VarChar(40)
  fecha_inicio   DateTime?   @db.Date
  fecha_fin      DateTime?   @db.Date
  id_accesorio   Int?
  id_cliente     Int?
  id_contrato    Int?
  resultado      Json?
  generado_por   String?     @db.VarChar(80)
  fecha_generado DateTime?   @default(now()) @db.Timestamp(6)
  descripcion    String?
  clientes       clientes?   @relation(fields: [id_cliente], references: [id_cliente], onUpdate: NoAction)
  accesorios     accesorios? @relation(fields: [id_accesorio], references: [id_equipo], onUpdate: NoAction, map: "analisis_id_equipo_fkey")
}

model audit_financial_events {
  id          Int       @id @default(autoincrement())
  evento      String?   @db.VarChar(100)
  tabla       String?   @db.VarChar(100)
  registro_id Int?
  usuario_id  Int?
  detalles    Json?
  fecha       DateTime? @default(now()) @db.Timestamptz(6)
}

model categorias {
  id_categoria     Int             @id @default(autoincrement())
  nombre_categoria String          @unique @db.VarChar(50)
  productos        productos[]
  subcategorias    subcategorias[]
}

model cliente_notificaciones {
  id                Int       @id @default(autoincrement())
  cliente_id        Int?      @unique
  email             String?   @db.VarChar(255)
  telefono          String?   @db.VarChar(20)
  preferencia_sms   Boolean?  @default(true)
  preferencia_email Boolean?  @default(true)
  preferencia_push  Boolean?  @default(false)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)
  clientes          clientes? @relation(fields: [cliente_id], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction)

  @@index([cliente_id], map: "idx_cliente_notif")
}

model cliente_push_subscriptions {
  id         Int       @id @default(autoincrement())
  cliente_id Int?
  endpoint   String    @unique
  p256dh     String    @db.VarChar(150)
  auth       String    @db.VarChar(150)
  user_agent String?
  activa     Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  clientes   clientes? @relation(fields: [cliente_id], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction)

  @@index([activa], map: "idx_push_sub_activa")
  @@index([cliente_id], map: "idx_push_sub_cliente")
}

